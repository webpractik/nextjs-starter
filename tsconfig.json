{
    "extends": "@repo/ts-config/base.json",
    "compilerOptions": {
        "paths": {
            "~/*": ["./*"],
            "@/*": ["./app/*"],
            "#/*": ["./src/*"]
        },
        "plugins": [{ "name": "next" }],
        "types": ["./src/types/global.d.ts"]
    },
    "include": ["next-env.d.ts", "**/*.ts", "**/*.tsx", ".next/types/**/*.ts"],
    "exclude": ["node_modules", ".next", "packages/api/codegen"]
}
