{
    "name": "nextjs-starter",
    "version": "8.0.0",
    "private": true,
    "type": "module",
    "scripts": {
        "build": "next build",
        "dev": "next dev --turbo",
        "prod": "node server.js || node .next/standalone/server.js",
        "tsc": "tsc --project tsconfig.json --noEmit --pretty",
        "lint": "eslint",
        "lint-fix": "eslint --fix",
        "unit-test": "vitest run",
        "unit-test-watch": "vitest",
        "unit-coverage": "vitest run --coverage",
        "e2e-test": "playwright test",
        "analyze": "ANALYZE=true npm run build",
        "client:rsdoctor": "rsdoctor analyze --profile .next/.rsdoctor/manifest.json",
        "server:rsdoctor": "rsdoctor analyze --profile .next/server/.rsdoctor/manifest.json",
        "knip": "knip --strict",
        "jscpd": "npx jscpd",
        "clean": "rimraf .next",
        "storybook": "storybook dev",
        "build-storybook": "storybook build"
    },
    "dependencies": {
        "@hookform/resolvers": "5.2.2",
        "@repo/api": "*",
        "@repo/core": "*",
        "@repo/design-tokens": "*",
        "@repo/logger": "*",
        "@repo/metrics": "*",
        "@sentry/nextjs": "10.47.0",
        "@t3-oss/env-nextjs": "0.13.11",
        "@tanstack/react-query": "5.96.2",
        "@vercel/otel": "2.1.1",
        "class-variance-authority": "0.7.1",
        "clsx": "2.1.1",
        "dayjs": "1.11.20",
        "framer-motion": "12.38.0",
        "isomorphic-dompurify": "3.7.1",
        "lodash-es": "4.18.1",
        "lucide-react": "1.7.0",
        "nanoid": "5.1.7",
        "next": "16.2.2",
        "nuqs": "2.8.9",
        "react": "19.2.4",
        "react-dom": "19.2.4",
        "react-hook-form": "7.72.1",
        "react-use": "17.6.0",
        "server-only": "0.0.1",
        "tailwind-merge": "3.5.0",
        "tsafe": "1.8.12",
        "zod": "4.3.6"
    },
    "devDependencies": {
        "@antfu/eslint-config": "8.0.0",
        "@eslint-react/eslint-plugin": "3.0.0",
        "@playwright/test": "1.59.1",
        "@repo/ts-config": "*",
        "@rsdoctor/cli": "1.5.7",
        "@rsdoctor/webpack-plugin": "1.5.7",
        "@storybook/addon-designs": "11.1.3",
        "@storybook/addon-docs": "10.3.4",
        "@storybook/addon-links": "10.3.4",
        "@storybook/addon-onboarding": "10.3.4",
        "@storybook/nextjs": "10.3.4",
        "@tailwindcss/postcss": "4.2.2",
        "@tailwindcss/typography": "0.5.19",
        "@testing-library/react": "16.3.2",
        "@testing-library/user-event": "14.6.1",
        "@total-typescript/ts-reset": "0.6.1",
        "@types/lodash-es": "4.17.12",
        "@types/node": "25.5.2",
        "@types/react": "19.2.14",
        "@types/react-dom": "19.2.3",
        "@typescript-eslint/utils": "8.58.0",
        "@vitejs/plugin-react": "6.0.1",
        "@vitest/browser": "4.1.2",
        "@vitest/browser-playwright": "4.1.2",
        "@vitest/coverage-v8": "4.1.2",
        "ajv": "8.18.0",
        "babel-plugin-react-compiler": "1.0.0",
        "commitizen": "4.3.1",
        "cssnano": "7.1.4",
        "cz-conventional-changelog": "3.3.0",
        "eslint": "10.2.0",
        "eslint-plugin-better-tailwindcss": "4.3.2",
        "eslint-plugin-format": "2.0.1",
        "eslint-plugin-react-hooks": "7.0.1",
        "eslint-plugin-react-refresh": "0.5.2",
        "jiti": "2.6.1",
        "jsdom": "29.0.1",
        "kill-port": "2.0.1",
        "knip": "6.3.0",
        "lefthook": "2.1.5",
        "lint-staged": "16.4.0",
        "postcss": "8.5.8",
        "prettier": "3.8.1",
        "rimraf": "6.1.3",
        "storybook": "10.3.4",
        "tailwindcss": "4.2.2",
        "tw-animate-css": "1.4.0",
        "type-fest": "5.5.0",
        "typed-query-selector": "2.12.1",
        "typescript": "6.0.2",
        "vite-tsconfig-paths": "6.1.1",
        "vitest": "4.1.2"
    },
    "config": {
        "commitizen": {
            "path": "./node_modules/cz-conventional-changelog"
        }
    },
    "browserslist": [
        "defaults",
        "not dead"
    ],
    "workspaces": [
        "packages/*"
    ],
    "trustedDependencies": [
        "@sentry/cli",
        "sharp"
    ],
    "overrides": {
        "storybook": "$storybook"
    }
}
