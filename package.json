{
    "name": "nextjs-starter",
    "version": "8.0.0",
    "private": true,
    "workspaces": [
        "packages/*"
    ],
    "type": "module",
    "scripts": {
        "analyze": "next experimental-analyze",
        "build": "next build",
        "build-storybook": "storybook build",
        "dev": "next dev --turbo",
        "fmt": "oxfmt",
        "fmt:check": "oxfmt --check",
        "jscpd": "npx jscpd",
        "knip": "knip --strict",
        "lint": "oxlint",
        "lint-fix": "oxlint --fix",
        "prod": "next start",
        "storybook": "storybook dev -p 6006",
        "test": "vitest run",
        "test:component": "vitest run --project component",
        "test:coverage": "vitest run --coverage",
        "test:e2e": "playwright test",
        "test:unit": "vitest run --project unit",
        "test:watch": "vitest",
        "tsc": "tsc --project tsconfig.json --noEmit --pretty"
    },
    "dependencies": {
        "@hookform/resolvers": "5.4.0",
        "@repo/api": "*",
        "@repo/core": "*",
        "@repo/design-tokens": "*",
        "@repo/logger": "*",
        "@repo/metrics": "*",
        "@sentry/nextjs": "10.58.0",
        "@t3-oss/env-nextjs": "0.13.11",
        "@tanstack/react-query": "5.101.0",
        "@tanstack/react-query-next-experimental": "5.101.0",
        "@vercel/otel": "2.1.3",
        "class-variance-authority": "0.7.1",
        "clsx": "2.1.1",
        "dayjs": "1.11.21",
        "framer-motion": "12.40.0",
        "isomorphic-dompurify": "3.17.0",
        "lodash-es": "4.18.1",
        "lucide-react": "1.20.0",
        "nanoid": "5.1.11",
        "next": "16.2.9",
        "nuqs": "2.8.9",
        "react": "19.2.7",
        "react-dom": "19.2.7",
        "react-hook-form": "7.79.0",
        "react-use": "17.6.1",
        "server-only": "0.0.1",
        "tailwind-merge": "3.6.0",
        "tsafe": "1.8.12",
        "zod": "4.4.3"
    },
    "devDependencies": {
        "@e18e/eslint-plugin": "0.5.1",
        "@eslint-community/eslint-plugin-eslint-comments": "4.7.2",
        "@next/eslint-plugin-next": "16.2.9",
        "@playwright/test": "1.61.0",
        "@repo/ts-config": "*",
        "@storybook/addon-a11y": "10.4.6",
        "@storybook/addon-designs": "11.1.3",
        "@storybook/addon-docs": "10.4.6",
        "@storybook/addon-links": "10.4.6",
        "@storybook/addon-onboarding": "10.4.6",
        "@storybook/addon-vitest": "10.4.6",
        "@storybook/nextjs-vite": "10.4.6",
        "@tailwindcss/postcss": "4.3.1",
        "@tailwindcss/typography": "0.5.20",
        "@total-typescript/ts-reset": "0.6.1",
        "@types/lodash-es": "4.17.12",
        "@types/node": "25.9.3",
        "@types/react": "19.2.17",
        "@types/react-dom": "19.2.3",
        "@typescript-eslint/utils": "8.61.1",
        "@vitejs/plugin-react": "6.0.2",
        "@vitest/browser": "4.1.9",
        "@vitest/browser-playwright": "4.1.9",
        "@vitest/coverage-v8": "4.1.9",
        "ajv": "8.20.0",
        "allure-js-commons": "3.10.0",
        "allure-vitest": "3.10.0",
        "babel-plugin-react-compiler": "1.0.0",
        "commitizen": "4.3.2",
        "cssnano": "8.0.2",
        "cz-conventional-changelog": "3.3.0",
        "eslint-plugin-antfu": "3.2.3",
        "eslint-plugin-better-tailwindcss": "4.6.0",
        "eslint-plugin-perfectionist": "5.9.1",
        "eslint-plugin-react-dom": "5.9.0",
        "eslint-plugin-react-naming-convention": "5.9.0",
        "eslint-plugin-react-rsc": "5.9.0",
        "eslint-plugin-react-web-api": "5.9.0",
        "eslint-plugin-regexp": "3.1.0",
        "eslint-plugin-storybook": "10.4.6",
        "eslint-plugin-unused-imports": "4.4.1",
        "knip": "6.17.1",
        "lefthook": "2.1.9",
        "oxfmt": "0.55.0",
        "oxlint": "1.70.0",
        "playwright": "1.61.0",
        "postcss": "8.5.15",
        "storybook": "10.4.6",
        "tailwindcss": "4.3.1",
        "tw-animate-css": "1.4.0",
        "type-fest": "5.7.0",
        "typed-query-selector": "2.12.2",
        "typescript": "6.0.3",
        "vite": "8.0.16",
        "vite-plugin-svgr": "5.2.0",
        "vitest": "4.1.9",
        "vitest-browser-react": "2.2.0"
    },
    "overrides": {
        "storybook": "$storybook"
    },
    "config": {
        "commitizen": {
            "path": "./node_modules/cz-conventional-changelog"
        }
    },
    "browserslist": [
        "defaults",
        "not dead"
    ],
    "trustedDependencies": [
        "@sentry/cli",
        "sharp"
    ]
}
